{
  "ConnectionStrings": {
    "DemoDB": "host=localhost;port=5432;database=configway;user id=postgres;password=postgres"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Branding": {
    "CompanyName": "Acme Corp",
    "SupportEmail": "support@acme.example.com",
    "SupportPhone": "+1-800-555-0100",
    "MarketingSiteUrl": "https://acme.example.com"
  },
  "Smtp": {
    "Host": "smtp.sendgrid.net",
    "Port": 587,
    "UseSsl": true,
    "FromAddress": "noreply@acme.example.com",
    "FromName": "Acme Corp"
  },
  "Identity": {
    "Authority": "https://login.acme.example.com",
    "Audience": "acme-api",
    "ClientId": "acme-spa",
    "AccessTokenLifetimeMinutes": 60,
    "RequireHttpsMetadata": true
  },
  "Storage": {
    "Provider": "S3",
    "Region": "eu-central-1",
    "BucketName": "acme-assets",
    "PresignedUrlTtlSeconds": 900
  },
  "Webhooks": {
    "MaxRetries": 3,
    "AllowedOrigins": [
      "https://app.acme.example.com",
      "https://admin.acme.example.com"
    ],
    "Endpoints": [
      {
        "Url": "https://hooks.acme.example.com/order-created",
        "Secret": "default-hmac-secret",
        "Event": "OrderCreated"
      }
    ]
  },
  "FeatureFlags": {
    "EnableNewCheckout": false,
    "EnableBetaBanner": false,
    "MaintenanceMode": false,
    "ReadOnlyMode": false
  }
}
